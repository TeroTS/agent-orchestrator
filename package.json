{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "node dist/src/app/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run test/real-integration.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "liquidjs": "^10.22.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.2.4"
  }
}
